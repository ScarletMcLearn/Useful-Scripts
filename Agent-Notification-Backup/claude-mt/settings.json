{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/credentials.json)",
      "Read(**/node_modules/**)",
      "Read(**/.next/**)",
      "Read(**/dist/**)",
      "Read(**/build/**)",
      "Read(**/coverage/**)",
      "Read(**/playwright-report/**)",
      "Read(**/test-results/**)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git commit *)",
      "Bash(npm install *)",
      "Bash(pnpm add *)",
      "Bash(pnpm install *)",
      "Bash(yarn add *)",
      "Bash(yarn install *)",
      "Bash(npm run test:e2e *)",
      "Bash(pnpm test:e2e *)",
      "Bash(playwright test *)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
  "Stop": [
  {
    "hooks": [
      {
        "type": "command",
        "shell": "powershell",
        "command": "& \"$HOME\\.config\\agent-notify\\Send-AgentNotification.ps1\" -Status Completed -UseHookInput",
        "timeout": 15
      }
    ]
  }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "& \"$HOME\\.config\\agent-notify\\Send-AgentNotification.ps1\" -Status Failed -Message 'Claude could not complete the current task.'",
            "timeout": 15
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "& \"$HOME\\.config\\agent-notify\\Send-AgentNotification.ps1\" -Status ActionRequired -Message 'Claude is waiting for permission approval.'",
            "timeout": 15
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "& \"$HOME\\.config\\agent-notify\\Send-AgentNotification.ps1\" -Status ActionRequired -Message 'Claude is waiting for information.'",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "agent_needs_input",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "& \"$HOME\\.config\\agent-notify\\Send-AgentNotification.ps1\" -Status ActionRequired -Message 'Claude needs your input.'",
            "timeout": 15
          }
        ]
      }
    ]
  },
  "model": "opus[1m]",
  "workflowKeywordTriggerEnabled": false,
  "viewMode": "focus",
  "alwaysThinkingEnabled": false,
  "effortLevel": "medium",
  "autoUpdatesChannel": "latest",
  "tui": "fullscreen",
  "autoMemoryEnabled": true,
  "skipWorkflowUsageWarning": false,
  "theme": "dark",
  "verbose": false,
  "autoCompactEnabled": true,
  "agentPushNotifEnabled": true,
  "inputNeededNotifEnabled": true,
  "attribution": {
    "commit": "",
    "pr": "",
    "sessionUrl": false
  }
}
